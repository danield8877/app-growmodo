# Copier vers .env et remplir les valeurs.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/revamperr?schema=public"
PORT=3001
JWT_SECRET=local_secret_dev_min_16_chars

# URL du frontend (lien sur la page d’accueil de l’API, et origine CORS de secours)
# Ex. https://amen-design.fr
PUBLIC_APP_URL=http://localhost:5173

# Origines CORS explicites (séparées par des virgules) = domaine exact du site Vite, avec schéma.
# Ex. https://amen-design.fr,https://www.amen-design.fr,http://localhost:5173
# Si vide, repli sur l’origine de PUBLIC_APP_URL ; si encore vide, CORS reste large (surtout en dev).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optionnel selon les fonctionnalités utilisées
GROK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
JINA_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stitch / Gemini (revamper avancé)
GOOGLE_CLOUD_PROJECT=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# GOOGLE_SERVICE_ACCOUNT_JSON=
